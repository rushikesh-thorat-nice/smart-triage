# Which backend to use: "anthropic" (direct API) or "bedrock" (AWS Bedrock)
LLM_PROVIDER=bedrock

# --- Anthropic direct API (used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=your-api-key-here

# --- AWS Bedrock (used when LLM_PROVIDER=bedrock) ---
# Uses your standard AWS credentials from ~/.aws/credentials or env vars.
AWS_REGION=us-east-1
# On Bedrock, model IDs are prefixed with "anthropic."
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# --- Other ---
SIMULATE=1
LOG_FILE=./sample_logs/app.log
DB_PATH=./data/incidents.db
CHROMA_DIR=./data/chroma
CONFIDENCE_THRESHOLD=0.85

# --- Email / SMTP notifications (Office 365) ---
# Leave SMTP_USER blank to disable email entirely.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=you@company.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Smart Triage

# JSON map of team slug → recipient email.
# Incidents routed to a team with no entry fall back to SMTP_FALLBACK_EMAIL.
TEAM_CONTACTS={"payments-oncall": "payments@company.com", "sre": "sre@company.com", "voice-platform-oncall": "oncall@company.com"}
SMTP_FALLBACK_EMAIL=oncall@company.com
